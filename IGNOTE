<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Games</title>

<style>
:root{
  --theme:#22ff88;
  --theme-rgb:34,255,136;
}

html,body{
  margin:0;
  padding:0;
  overflow:hidden;
  font-family:system-ui,sans-serif;
  background:black;
  color:var(--theme);
  user-select:none; /* all text unselectable */
}

canvas{
  position:fixed;
  inset:0;
  z-index:0;
}

/* WELCOME BOX */
#leftText{
  position:fixed;
  top:clamp(12px,2vh,20px);
  left:clamp(16px,3vw,40px);
  width:clamp(200px,20vw,260px);
  padding:clamp(12px,1.5vw,18px);
  border-radius:12px;
  border:1px solid rgba(var(--theme-rgb),0.7);
  background:rgba(0,0,0,0.25);
  backdrop-filter:blur(12px);
  display:flex;
  flex-direction:column;
  gap:6px;
  box-shadow:
    0 0 6px rgba(var(--theme-rgb),0.3),
    0 0 18px rgba(var(--theme-rgb),0.1);
  animation:glowPulse 3s infinite alternate;
  z-index:5;
}
#leftText h1{margin:0;font-size:clamp(20px,2.2vw,26px);}
#leftText p{margin:0;font-size:clamp(12px,1.2vw,14px);opacity:.85;}

/* BUTTONS */
#buttons{
  position:fixed;
  top:140px;
  left:40px;
  display:grid;
  grid-template-columns:repeat(3,120px);
  gap:8px;
  z-index:5;
}
button{
  height:32px;
  border-radius:6px;
  border:1px solid rgba(var(--theme-rgb),0.5);
  background:rgba(0,0,0,0.3);
  color:var(--theme);
  cursor:pointer;
  box-shadow:
    0 0 6px rgba(var(--theme-rgb),0.3),
    0 0 16px rgba(var(--theme-rgb),0.2);
  transition:.2s;
}
button:hover{
  box-shadow:
    0 0 10px rgba(var(--theme-rgb),0.6),
    0 0 22px rgba(var(--theme-rgb),0.4);
}

/* ICON BUTTONS */
.iconBtn{
  position:fixed;
  top:20px;
  width:42px;height:42px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  border:1px solid rgba(var(--theme-rgb),0.6);
  background:rgba(0,0,0,0.35);
  cursor:pointer;
  z-index:5;
  box-shadow:
    0 0 8px rgba(var(--theme-rgb),0.5),
    0 0 20px rgba(var(--theme-rgb),0.25);
}
#customizeBubble{right:20px;}
#updatesButton{right:75px;}

/* PANELS */
.panel{
  position:absolute;
  width:260px;
  border-radius:12px;
  background:rgba(0,0,0,0.4);
  display:none;
  border:1px solid rgba(var(--theme-rgb),0.5);
  backdrop-filter:blur(10px);
  z-index:10;
  box-shadow:
    0 0 16px rgba(var(--theme-rgb),0.5),
    0 0 35px rgba(var(--theme-rgb),0.2);
}
.panelHeader{
  padding:12px;
  display:flex;
  justify-content:space-between;
  cursor:grab;
}
.panelContent{
  padding:16px;
  display:flex;
  flex-direction:column;
  gap:10px;
}

/* DROPDOWN */
.dropdown{position:relative;}
.dropdown-selected{
  padding:8px;
  border-radius:6px;
  border:1px solid rgba(var(--theme-rgb),0.5);
  background:black;
  cursor:pointer;
  box-shadow:0 0 6px rgba(var(--theme-rgb),0.3);
}
.dropdown-options{
  position:absolute;
  top:110%;
  width:100%;
  background:black;
  border-radius:6px;
  display:none;
  overflow:hidden;
}
.dropdown-options div{
  padding:8px;
  cursor:pointer;
}
.dropdown-options div:hover{
  background:rgba(var(--theme-rgb),0.2);
}

/* OVERLAY */
#overlay{
  position:fixed;
  inset:0;
  background:black;
  display:none;
  z-index:20;
}
#overlay iframe{width:100%;height:100%;border:none;}
#overlayControls{
  position:absolute;
  top:15px;
  right:15px;
  display:flex;
  gap:10px;
}

/* GLOW ANIMATION */
@keyframes glowPulse{
  from{
    box-shadow:
      0 0 6px rgba(var(--theme-rgb),0.2),
      0 0 18px rgba(var(--theme-rgb),0.08);
  }
  to{
    box-shadow:
      0 0 10px rgba(var(--theme-rgb),0.5),
      0 0 25px rgba(var(--theme-rgb),0.2);
  }
}
</style>
</head>
<body>

<canvas id="space"></canvas>

<div id="leftText">
  <h1>Welcome</h1>
  <p>Be Responsible</p>
</div>

<div id="buttons">
  <button onclick="openGame('https://irv77.github.io/hd_fnaf/1/')">FNAF 1</button>
  <button onclick="openGame('https://irv77.github.io/hd_fnaf/2/')">FNAF 2</button>
  <button onclick="openGame('https://irv77.github.io/hd_fnaf/3/')">FNAF 3</button>
  <button onclick="openGame('https://irv77.github.io/hd_fnaf/4/')">FNAF 4</button>
  <button id="minecraftButton">Minecraft</button>
  <button onclick="openGame('https://freesh11.github.io/Games/fnae.html')">FNAE</button>
  <button onclick="openGame('https://omegafredo.github.io/worst-time-simulator/')">Worst Time Simulator</button>
</div>

<div id="customizeBubble" class="iconBtn" onclick="openPanel(settingsPanel)">✎</div>
<div id="updatesButton" class="iconBtn" onclick="openPanel(updatesPanel)">📓</div>

<div id="overlay">
  <div id="overlayControls">
    <button onclick="closeGame()">✕</button>
    <button onclick="openStealthTab()">⛶</button>
  </div>
  <iframe id="gameFrame"></iframe>
</div>

<div id="settingsPanel" class="panel">
  <div class="panelHeader">
    <span>Customization</span>
    <span onclick="closePanel(settingsPanel)">✕</span>
  </div>
  <div class="panelContent">
    <span>Theme</span>
    <div class="dropdown">
      <div class="dropdown-selected" onclick="toggleDropdown()">Green</div>
      <div class="dropdown-options">
        <div onclick="selectTheme('#22ff88','Green')">Green</div>
        <div onclick="selectTheme('#3a7bff','Blue')">Blue</div>
        <div onclick="selectTheme('#ff3a3a','Red')">Red</div>
        <div onclick="selectTheme('#a855f7','Purple')">Purple</div>
        <div onclick="selectTheme('#00ffff','Cyan')">Cyan</div>
        <div onclick="selectTheme('#ffcc00','Gold')">Gold</div>
        <div onclick="selectTheme('#ff66cc','Pink')">Pink</div>
        <div onclick="selectTheme('#00ffcc','Aqua')">Aqua</div>
        <div onclick="selectTheme('#ffffff','White')">White</div>
      </div>
    </div>
  </div>
</div>

<div id="updatesPanel" class="panel">
  <div class="panelHeader">
    <span>Updates</span>
    <span onclick="closePanel(updatesPanel)">✕</span>
  </div>
  <div class="panelContent">
    <div>✨ Added glow upgrade</div>
    <div>🎨 Added more themes</div>
  </div>
</div>

<script>
/* ========== CONSTELLATIONS ========== */
const canvas=document.getElementById("space");
const ctx=canvas.getContext("2d");
let stars=[], mouse={x:0,y:0};
function resize(){canvas.width=innerWidth;canvas.height=innerHeight;}
window.onresize=resize; resize();
for(let i=0;i<120;i++){stars.push({x:Math.random()*canvas.width,y:Math.random()*canvas.height,vx:(Math.random()-0.5)*0.4,vy:(Math.random()-0.5)*0.4});}
window.onmousemove=e=>{mouse.x=e.clientX; mouse.y=e.clientY;};
function animate(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  for(let s of stars){
    s.x+=s.vx; s.y+=s.vy;
    if(s.x<0||s.x>canvas.width)s.vx*=-1;
    if(s.y<0||s.y>canvas.height)s.vy*=-1;
    let dx=s.x-mouse.x, dy=s.y-mouse.y, dist=Math.sqrt(dx*dx+dy*dy);
    if(dist<120){let force=(120-dist)/120; s.vx+=dx/dist*0.05; s.vy+=dy/dist*0.05;}
    ctx.fillStyle="white"; ctx.fillRect(s.x,s.y,2,2);
  }
  for(let i=0;i<stars.length;i++){
    for(let j=i+1;j<stars.length;j++){
      let dx=stars[i].x-stars[j].x, dy=stars[i].y-stars[j].y, dist=Math.sqrt(dx*dx+dy*dy);
      if(dist<100){
        ctx.strokeStyle=`rgba(255,255,255,${1-dist/100})`;
        ctx.beginPath(); ctx.moveTo(stars[i].x,stars[i].y);
        ctx.lineTo(stars[j].x,stars[j].y); ctx.stroke();
      }
    }
  }
  requestAnimationFrame(animate);
}
animate();

/* ========== PANEL DRAGGING ========== */
let active=null, ox=0, oy=0, zIndex=100;
document.querySelectorAll(".panelHeader").forEach(header=>{
  header.onmousedown=e=>{
    active=header.parentElement; ox=e.clientX-active.offsetLeft; oy=e.clientY-active.offsetTop; active.style.zIndex=++zIndex;
  };
});
document.onmousemove=e=>{
  if(!active)return;
  let x=e.clientX-ox, y=e.clientY-oy;
  x=Math.max(0, Math.min(innerWidth-active.offsetWidth,x));
  y=Math.max(0, Math.min(innerHeight-active.offsetHeight,y));
  active.style.left=x+"px"; active.style.top=y+"px";
};
document.onmouseup=()=>active=null;

/* ========== GAME & THEME ========== */
const overlay=document.getElementById("overlay");
const gameFrame=document.getElementById("gameFrame");
const settingsPanel=document.getElementById("settingsPanel");
const updatesPanel=document.getElementById("updatesPanel");

function openGame(url){
  overlay.style.display="block"; gameFrame.src=url;
}
function closeGame(){overlay.style.display="none"; gameFrame.src="";}
function openStealthTab(){
  const tab=window.open("about:blank","_blank");
  tab.document.write(`<title>.</title><iframe src="${gameFrame.src}" style="width:100%;height:100%;border:none"></iframe>`);
}
function openPanel(p){
  p.style.display="block";
  p.style.left=(window.innerWidth-p.offsetWidth)/2+"px";
  p.style.top=(window.innerHeight-p.offsetHeight)/2+"px";
}
function closePanel(p){p.style.display="none";}
function toggleDropdown(){
  const menu=document.querySelector(".dropdown-options");
  menu.style.display=menu.style.display==="block"?"none":"block";
}
function selectTheme(color,name){
  document.querySelector(".dropdown-selected").innerText=name;
  document.documentElement.style.setProperty("--theme",color);
  document.documentElement.style.setProperty("--theme-rgb",hexToRgb(color));
  document.querySelector(".dropdown-options").style.display="none";
}
function hexToRgb(hex){let c=hex.substring(1); let num=parseInt(c,16); return (num>>16&255)+","+(num>>8&255)+","+(num&255);}

/* ========== MINECRAFT CURSOR LOCK ========== */
const minecraftButton=document.getElementById('minecraftButton');
minecraftButton.addEventListener('click', ()=>{
  openGame('https://freesh11.github.io/Games/EaglercraftX_1.8_WASM-GC_Offline_Download.html');

  gameFrame.onload = ()=>{
    gameFrame.contentWindow.document.addEventListener('click', ()=>{
      if(gameFrame.requestPointerLock){ gameFrame.requestPointerLock(); }
      else if(gameFrame.contentWindow.document.body.requestPointerLock){
        gameFrame.contentWindow.document.body.requestPointerLock();
      }
    }, { once:true });
  };
});
</script>

</body>
</html>
